{
  "name": "eurekai",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n srv,web -c blue,green \"tsx watch server.ts\" \"vite\"",
    "dev:server": "tsx watch server.ts",
    "dev:web": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "tsx server.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "dependencies": {
    "@elevenlabs/elevenlabs-js": "^2.36.0",
    "@mistralai/mistralai": "^2.1.2",
    "alpinejs": "^3.15.8",
    "dotenv": "^17.0.0",
    "express": "^5.0.0",
    "ffmpeg-static": "^5.3.0",
    "lucide": "^1.0.0",
    "marked": "^17.0.3",
    "multer": "^2.0.0"
  },
  "overrides": {
    "vite-plugin-handlebars": {
      "vite": "$vite"
    }
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.19.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vite-plugin-handlebars": "^2.0.0",
    "vitest": "^4.0.18"
  }
}
