MISTRAL_API_KEY=your_mistral_api_key_here
# Optional: only needed if ttsProvider is set to "elevenlabs"
# If using Mistral TTS (Voxtral), this is not required
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# Optional: only needed for CI/SonarCloud analysis, not required for running the app
SONAR_TOKEN=your_sonarcloud_token_here
